# Fichier de référence pour les variables d'environnement de production.
# NE PAS committer ce fichier avec des secrets réels.
# Sur Render : configurer ces variables directement dans le dashboard Render
# (Environment > Environment Variables), PAS via un fichier .env.

###> symfony/framework-bundle ###
APP_ENV=prod
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://votre-domaine.onrender.com
###< symfony/routing ###

###> symfony/mailer ###
# Configurer selon votre fournisseur (ex: Mailgun, Sendgrid, Brevo, etc.)
MAILER_DSN=smtp://user:password@smtp.example.com:587
###< symfony/mailer ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# Fournir par Render via une base MySQL/PostgreSQL managée
DATABASE_URL=mysql://user:password@host:3306/database?serverVersion=8.0.32&charset=utf8mb4
###< doctrine/doctrine-bundle ###
