{% extends 'base.html.twig' %}

{% block title %}Objets trouvés - BoisguiBad{% endblock %}

{% block body %}
<div class="px-4">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Objets trouvés</h1>
        <a href="{{ path('lost_item_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">
            + Déclarer un objet
        </a>
    </div>

    {% if lostItems is empty %}
        <p class="text-gray-500">Aucun objet trouvé enregistré.</p>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for item in lostItems %}
            <div class="bg-white shadow rounded-lg p-4">
                <p class="text-sm font-medium text-gray-900 mb-2">{{ item.description }}</p>
                <p class="text-xs text-gray-500">Trouvé le {{ item.foundAt|date('d/m/Y') }}</p>
                {% if item.location %}
                    <p class="text-xs text-gray-500">📍 {{ item.location }}</p>
                {% endif %}
                <div class="mt-3 flex items-center justify-between">
                    <span class="px-2 py-1 rounded-full text-xs {% if item.status.value == 'TROUVE' %}bg-yellow-100 text-yellow-700{% else %}bg-green-100 text-green-700{% endif %}">
                        {{ item.status.label() }}
                    </span>
                    <span class="text-xs text-gray-400">par {{ item.declaredBy.fullName }}</span>
                </div>
            </div>
        {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
