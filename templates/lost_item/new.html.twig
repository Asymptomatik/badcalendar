{% extends 'base.html.twig' %}

{% block title %}Déclarer un objet trouvé - BoisguiBad{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto bg-white shadow-lg rounded-lg p-8">
    <h1 class="text-2xl font-bold text-blue-800 mb-6">Déclarer un objet trouvé</h1>

    {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
        <div>
            {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2', 'rows': '3'}}) }}
            {{ form_errors(form.description) }}
        </div>
        <div>
            {{ form_label(form.foundAt, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.foundAt, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            {{ form_errors(form.foundAt) }}
        </div>
        <div>
            {{ form_label(form.location, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.location, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
        </div>
        <button type="submit" class="w-full bg-blue-800 text-white py-2 px-4 rounded-md hover:bg-blue-700 font-medium">
            Déclarer l'objet
        </button>
    {{ form_end(form) }}
</div>
{% endblock %}
