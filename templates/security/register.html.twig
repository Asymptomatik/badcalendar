{% extends 'base.html.twig' %}

{% block title %}Inscription - BoisguiBad{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto bg-white shadow-lg rounded-lg p-8 mt-8">
    <h1 class="text-2xl font-bold text-blue-800 mb-6">Créer un compte</h1>

    {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
        <div>
            {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.firstName, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            {{ form_errors(form.firstName) }}
        </div>
        <div>
            {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.lastName, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            {{ form_errors(form.lastName) }}
        </div>
        <div>
            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            {{ form_errors(form.email) }}
        </div>
        <div>
            {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.phone, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
        </div>
        <div>
            {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
        </div>
        <div>
            {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            {{ form_errors(form.plainPassword) }}
        </div>
        <button type="submit" class="w-full bg-blue-800 text-white py-2 px-4 rounded-md hover:bg-blue-700 font-medium">
            Créer mon compte
        </button>
    {{ form_end(form) }}

    <p class="mt-4 text-center text-sm text-gray-600">
        Déjà inscrit ?
        <a href="{{ path('security_login') }}" class="text-blue-600 hover:underline">Se connecter</a>
    </p>
</div>
{% endblock %}
