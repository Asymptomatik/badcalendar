{% extends 'base.html.twig' %}

{% block title %}{{ user.fullName }} - Admin BoisguiBad{% endblock %}

{% block body %}
<div class="px-4 max-w-2xl">
    <div class="mb-4">
        <a href="{{ path('admin_member_list') }}" class="text-blue-600 hover:underline text-sm">← Retour aux membres</a>
    </div>

    <div class="bg-white shadow rounded-lg p-6 mb-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-4">{{ user.fullName }}</h1>
        <dl class="grid grid-cols-2 gap-4 text-sm">
            <div><dt class="font-medium text-gray-500">Email</dt><dd>{{ user.email }}</dd></div>
            <div><dt class="font-medium text-gray-500">Téléphone</dt><dd>{{ user.phone ?? 'Non renseigné' }}</dd></div>
            <div><dt class="font-medium text-gray-500">Niveau</dt><dd>{{ user.level ?? 'Non renseigné' }}</dd></div>
            <div>
                <dt class="font-medium text-gray-500">Type de membre</dt>
                <dd>{{ user.memberType ? user.memberType.label() : 'Non assigné' }}</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-500">Compte vérifié</dt>
                <dd>{% if user.isVerified %}Oui{% else %}Non{% endif %}</dd>
            </div>
        </dl>
    </div>

    <!-- Assigner le type -->
    <div class="bg-white shadow rounded-lg p-6 mb-4">
        <h2 class="text-lg font-semibold mb-4">Assigner le type de membre</h2>
        <form method="post" action="{{ path('admin_member_set_type', {id: user.id}) }}" class="flex gap-4">
            <input type="hidden" name="_token" value="{{ csrf_token('member_type_' ~ user.id) }}">
            <select name="member_type" class="border border-gray-300 rounded-md px-3 py-2 text-sm">
                <option value="LOISIR" {% if user.memberType and user.memberType.value == 'LOISIR' %}selected{% endif %}>Loisir</option>
                <option value="COMPETITEUR" {% if user.memberType and user.memberType.value == 'COMPETITEUR' %}selected{% endif %}>Compétiteur</option>
            </select>
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">Enregistrer</button>
        </form>
    </div>

    {% if not user.isVerified %}
    <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-4">Valider le compte</h2>
        <form method="post" action="{{ path('admin_member_verify', {id: user.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('member_verify_' ~ user.id) }}">
            <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm hover:bg-green-700">Valider le compte</button>
        </form>
    </div>
    {% endif %}
</div>
{% endblock %}
