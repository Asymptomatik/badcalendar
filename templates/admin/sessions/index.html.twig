{% extends 'base.html.twig' %}

{% block title %}Séances - Admin BoisguiBad{% endblock %}

{% block body %}
<div class="px-4">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Gestion des séances</h1>

    <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Responsable</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Inscrits</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
            {% for session in sessions %}
                <tr class="{% if not session.responsableKeys and session.type.value != 'DIMANCHE' %}bg-red-50{% endif %}">
                    <td class="px-6 py-4 text-sm font-medium">{{ session.type.label() }}</td>
                    <td class="px-6 py-4 text-sm text-gray-600">{{ session.date|date('d/m/Y H:i') }}</td>
                    <td class="px-6 py-4 text-sm">
                        {% if session.responsableKeys %}
                            {{ session.responsableKeys.fullName }}
                        {% elseif session.type.value != 'DIMANCHE' %}
                            <span class="text-red-500">⚠ Non assigné</span>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 text-sm">{{ session.registrations|length }}</td>
                    <td class="px-6 py-4 text-sm">
                        <a href="{{ path('admin_session_edit', {id: session.id}) }}" class="text-blue-600 hover:underline">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
