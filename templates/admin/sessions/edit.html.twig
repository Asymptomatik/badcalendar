{% extends 'base.html.twig' %}

{% block title %}Modifier la séance - Admin BoisguiBad{% endblock %}

{% block body %}
<div class="px-4 max-w-2xl">
    <div class="mb-4">
        <a href="{{ path('admin_session_list') }}" class="text-blue-600 hover:underline text-sm">← Retour aux séances</a>
    </div>

    <div class="bg-white shadow rounded-lg p-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Modifier la séance {{ session.type.label() }}</h1>

        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
            <div>
                {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.type, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            </div>
            <div>
                {{ form_label(form.date, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            </div>
            <div>
                {{ form_label(form.location, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.location, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            </div>
            <div>
                {{ form_label(form.responsableKeys, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.responsableKeys, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
            </div>
            <div>
                {{ form_label(form.notes, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2', 'rows': '3'}}) }}
            </div>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 font-medium">
                Enregistrer
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
