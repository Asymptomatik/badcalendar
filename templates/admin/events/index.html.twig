{% extends 'base.html.twig' %}
{% block title %}Événements - Admin BoisguiBad{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-8">
    <div>
        <a href="{{ path('admin_dashboard') }}" class="back-link flex items-center gap-1">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Tableau de bord
        </a>
        <h1 class="text-2xl font-bold text-on-surface mt-1">Gestion des événements</h1>
    </div>
    <a href="{{ path('admin_event_new') }}" class="btn-primary flex items-center gap-2">
        <span class="material-symbols-outlined text-base">add</span>
        Nouvel événement
    </a>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <table class="min-w-full">
        <thead class="bg-surface-container-low">
            <tr>
                <th class="th">Titre</th>
                <th class="th">Date</th>
                <th class="th">Places max</th>
                <th class="th">Inscriptions</th>
                <th class="th"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
        {% for event in events %}
            <tr class="hover:bg-surface-container transition-colors">
                <td class="td-bold">{{ event.title }}</td>
                <td class="td">{{ event.date|date('d/m/Y') }}</td>
                <td class="td">
                    {% if event.maxParticipants %}
                        <span class="badge-slate">{{ event.maxParticipants }}</span>
                    {% else %}
                        <span class="text-on-surface-variant">∞</span>
                    {% endif %}
                </td>
                <td class="td">{{ event.registrations|length }}</td>
                <td class="px-6 py-4 text-right">
                    <a href="{{ path('admin_event_registrations', {id: event.id}) }}" class="btn-ghost text-xs flex items-center gap-1 justify-end">
                        <span class="material-symbols-outlined text-base">people</span>
                        Inscriptions
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
