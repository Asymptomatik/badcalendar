{% extends 'base.html.twig' %}

{% block title %}Inscriptions - {{ event.title }}{% endblock %}

{% block body %}
<div class="px-4">
    <div class="mb-4">
        <a href="{{ path('admin_event_list') }}" class="text-blue-600 hover:underline text-sm">← Retour aux événements</a>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Inscriptions — {{ event.title }}</h1>

    <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Membre</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Confirmé le</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Inscrit le</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
            {% for reg in event.registrations %}
                <tr>
                    <td class="px-6 py-4 text-sm font-medium">{{ reg.user.fullName }}</td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded-full text-xs
                            {% if reg.status.value == 'INSCRIT' %}bg-green-100 text-green-700
                            {% elseif reg.status.value == 'DESISTE' %}bg-red-100 text-red-700
                            {% else %}bg-yellow-100 text-yellow-700{% endif %}">
                            {{ reg.status.label() }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500">
                        {{ reg.confirmedAt ? reg.confirmedAt|date('d/m/Y') : '—' }}
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500">{{ reg.createdAt|date('d/m/Y') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
