{% extends 'base.html.twig' %}
{% block title %}Inscriptions {{ event.title }} - Admin{% endblock %}

{% block body %}
<a href="{{ path('admin_event_list') }}" class="back-link flex items-center gap-1">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    Retour aux événements
</a>

<div class="mb-8 mt-4">
    <h1 class="text-2xl font-bold text-on-surface">{{ event.title }}</h1>
    <p class="text-on-surface-variant text-sm mt-1">
        <span class="material-symbols-outlined text-base align-middle">people</span>
        {{ event.registrations|length }} inscription(s)
    </p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <table class="min-w-full">
        <thead class="bg-surface-container-low">
            <tr>
                <th class="th">Membre</th>
                <th class="th">Email</th>
                <th class="th">Statut</th>
                <th class="th">Date inscription</th>
                <th class="th">Confirmé le</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
        {% for reg in event.registrations %}
            <tr class="hover:bg-surface-container transition-colors">
                <td class="td-bold">{{ reg.user.fullName }}</td>
                <td class="td text-on-surface-variant">{{ reg.user.email }}</td>
                <td class="td">
                    <span class="{% if reg.status.value == 'INSCRIT' %}badge-secondary{% elseif reg.status.value == 'DESISTE' %}badge-error{% else %}badge-amber{% endif %}">
                        {{ reg.status.label() }}
                    </span>
                </td>
                <td class="td">{{ reg.createdAt|date('d/m/Y') }}</td>
                <td class="td">{{ reg.confirmedAt ? reg.confirmedAt|date('d/m/Y') : '—' }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
