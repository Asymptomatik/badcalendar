{% extends 'base.html.twig' %}
{% block title %}Nouvel événement - Admin{% endblock %}

{% block body %}
<a href="{{ path('admin_event_list') }}" class="back-link flex items-center gap-1">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    Retour aux événements
</a>

<div class="mb-6 mt-2">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-on-surface-variant">Admin / Événements / Nouvel événement</p>
    <div class="mt-3 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Créer un événement</h1>
            <p class="text-on-surface-variant text-sm mt-1">Remplissez les informations ci-dessous pour planifier une nouvelle activité pour le club.</p>
        </div>
        <div class="inline-flex items-center gap-2 rounded-full bg-primary-fixed px-3 py-1.5 text-xs font-semibold text-on-primary-fixed w-fit">
            <span class="material-symbols-outlined text-sm">event_upcoming</span>
            Publication après enregistrement
        </div>
    </div>
</div>

<div class="grid gap-6 xl:grid-cols-[minmax(0,2fr)_20rem]">
    <div class="bg-surface-container-lowest rounded-xl shadow-sm p-6 lg:p-7">
        {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}
            <div>
                {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Tournoi interne de printemps'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div>
                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-textarea', 'rows': '5', 'placeholder': 'Programme, format, informations utiles pour les membres…'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    {{ form_label(form.date, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.date, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.date) }}
                </div>
                <div>
                    {{ form_label(form.registrationDeadline, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.registrationDeadline, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.registrationDeadline) }}
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)]">
                <div>
                    {{ form_label(form.location, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.location, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Gymnase Jean Moulin'}}) }}
                    {{ form_errors(form.location) }}
                </div>
                <div>
                    {{ form_label(form.maxParticipants, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.maxParticipants, {'attr': {'class': 'form-input', 'placeholder': 'Ex: 32'}}) }}
                    {{ form_errors(form.maxParticipants) }}
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-3">
                <button type="submit" class="btn-primary">Créer l'événement</button>
                <a href="{{ path('admin_event_list') }}" class="btn-secondary">Annuler</a>
                <a href="{{ path('admin_event_list') }}" class="text-sm font-semibold text-primary hover:underline inline-flex items-center gap-1.5 px-1 py-2">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Retour à la liste
                </a>
            </div>
        {{ form_end(form) }}
    </div>

    <div class="space-y-4">
        <div class="card p-5 bg-surface-container-low">
            <h2 class="text-sm font-semibold text-on-surface mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-base">tips_and_updates</span>
                Conseils d'organisation
            </h2>
            <ul class="space-y-2.5 text-sm text-on-surface-variant leading-relaxed">
                <li>Précisez le lieu exact et les horaires pour limiter les questions des membres.</li>
                <li>Définissez une date limite d'inscription si vous devez confirmer une réservation.</li>
                <li>Indiquez le nombre de places quand l'événement est contraint par la capacité du gymnase.</li>
            </ul>
        </div>

        <div class="card p-5">
            <h2 class="text-sm font-semibold text-on-surface mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-base">visibility</span>
                Aperçu rapide
            </h2>
            <div class="space-y-3 text-sm">
                <div class="rounded-xl bg-surface-container-low p-4">
                    <p class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1">Statut</p>
                    <p class="font-semibold text-on-surface">Brouillon administrateur</p>
                </div>
                <div class="rounded-xl bg-surface-container-low p-4">
                    <p class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1">Audience</p>
                    <p class="text-on-surface">Tous les membres verront l'événement dès sa création.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
