{% extends 'base.html.twig' %}

{% block title %}Nouvel événement - Admin BoisguiBad{% endblock %}

{% block body %}
<div class="px-4 max-w-2xl">
    <div class="mb-4">
        <a href="{{ path('admin_event_list') }}" class="text-blue-600 hover:underline text-sm">← Retour</a>
    </div>

    <div class="bg-white shadow rounded-lg p-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Créer un événement</h1>

        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
            {% for field in form %}
                <div>
                    {{ form_label(field, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(field, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2'}}) }}
                    {{ form_errors(field) }}
                </div>
            {% endfor %}
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 font-medium">
                Créer l'événement
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
