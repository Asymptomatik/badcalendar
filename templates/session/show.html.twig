{% extends 'base.html.twig' %}
{% block title %}Séance {{ session.type.label() }} - BoisguiBad{% endblock %}

{% block body %}
<a href="{{ path('session_list') }}" class="back-link">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    Retour aux séances
</a>

<div class="max-w-3xl space-y-6">

    <div class="bg-surface-container-lowest rounded-xl shadow-sm p-6">
        <div class="flex items-start justify-between mb-6">
            <div>
                <span class="{% if session.type.value == 'MERCREDI' %}badge-violet{% elseif session.type.value == 'DIMANCHE' %}badge-amber{% else %}badge-primary{% endif %} mb-3 inline-block">
                    {{ session.type.label() }}
                </span>
                <h1 class="text-2xl font-bold text-on-surface">Séance {{ session.type.label() }}</h1>
                <p class="text-on-surface-variant text-sm mt-1">{{ session.date|date('d/m/Y à H:i') }}</p>
            </div>
        </div>

        <div class="dl-grid mb-6">
            <div class="dl-item">
                <dt class="dl-label">Lieu</dt>
                <dd class="dl-value">{{ session.location ?? 'Non défini' }}</dd>
            </div>
            <div class="dl-item">
                <dt class="dl-label">Responsable clés</dt>
                <dd class="dl-value {% if not session.responsableKeys %}text-on-error-container{% endif %}">
                    {% if session.responsableKeys %}{{ session.responsableKeys.fullName }}{% else %}Non assigné{% endif %}
                </dd>
            </div>
            {% if session.notes %}
            <div class="dl-item sm:col-span-2">
                <dt class="dl-label">Notes</dt>
                <dd class="dl-value">{{ session.notes }}</dd>
            </div>
            {% endif %}
        </div>

        {% if canAccess %}
            {% if isRegistered %}
                <form method="post" action="{{ path('session_unregister', {id: session.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('session_unregister_' ~ session.id) }}">
                    <button type="submit" class="btn-danger">Se désinscrire</button>
                </form>
            {% else %}
                <form method="post" action="{{ path('session_register', {id: session.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('session_register_' ~ session.id) }}">
                    <button type="submit" class="btn-primary">S'inscrire à cette séance</button>
                </form>
            {% endif %}
        {% else %}
            <div class="bg-error-container text-on-error-container rounded-lg p-4 flex items-center gap-3">
                <span class="material-symbols-outlined text-base">warning</span>
                Vous n'avez pas accès à cette séance (vérifiez votre type de membership).
            </div>
        {% endif %}
    </div>

    <div class="bg-surface-container-lowest rounded-xl shadow-sm p-6">
        <h2 class="font-semibold text-on-surface mb-4">
            Inscrits <span class="badge-slate ml-2">{{ session.registrations|length }}</span>
        </h2>
        {% if session.registrations is empty %}
            <p class="text-on-surface-variant text-sm">Aucun inscrit pour le moment.</p>
        {% else %}
            <ul class="divide-y divide-outline-variant">
            {% for reg in session.registrations %}
                <li class="py-2.5 flex items-center gap-3 text-sm">
                    <span class="w-8 h-8 rounded-full bg-primary-fixed text-on-primary-fixed flex items-center justify-center font-semibold text-xs flex-shrink-0">
                        {{ reg.user.fullName|slice(0, 1)|upper }}
                    </span>
                    <span class="font-medium text-on-surface">{{ reg.user.fullName }}</span>
                </li>
            {% endfor %}
            </ul>
        {% endif %}
    </div>

</div>
{% endblock %}
