{% extends 'base.html.twig' %}

{% block title %}Mes événements - BoisguiBad{% endblock %}

{% block body %}
<div class="px-4">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Mes inscriptions aux événements</h1>
    {% if registrations is empty %}
        <p class="text-gray-500">Vous n'êtes inscrit à aucun événement.</p>
    {% else %}
        <div class="bg-white shadow rounded-lg overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Événement</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                {% for reg in registrations %}
                    <tr>
                        <td class="px-6 py-4 text-sm font-medium">{{ reg.event.title }}</td>
                        <td class="px-6 py-4 text-sm text-gray-500">{{ reg.event.date|date('d/m/Y') }}</td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 rounded-full text-xs
                                {% if reg.status.value == 'INSCRIT' %}bg-green-100 text-green-700
                                {% elseif reg.status.value == 'DESISTE' %}bg-red-100 text-red-700
                                {% else %}bg-yellow-100 text-yellow-700{% endif %}">
                                {{ reg.status.label() }}
                            </span>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
