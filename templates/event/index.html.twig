{% extends 'base.html.twig' %}
{% block title %}Événements - BoisguiBad{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-on-surface">Événements & Tournois</h1>
        <p class="text-on-surface-variant text-sm mt-1">Inscrivez-vous aux prochains événements du club</p>
    </div>
    <a href="{{ path('event_my_events') }}" class="btn-secondary">Mes inscriptions</a>
</div>

{% if upcomingEvents is empty %}
    <div class="bg-surface-container-lowest rounded-xl shadow-sm p-12 text-center">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant mb-3 block">emoji_events</span>
        <p class="text-on-surface-variant font-medium">Aucun événement à venir pour le moment.</p>
    </div>
{% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for event in upcomingEvents %}
        <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden flex flex-col">
            <div class="h-1.5 bg-primary"></div>
            <div class="p-6 flex flex-col flex-1">
                <h2 class="font-bold text-on-surface text-lg mb-3">{{ event.title }}</h2>
                <div class="space-y-1.5 text-sm text-on-surface-variant flex-1">
                    <p class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">calendar_month</span>
                        {{ event.date|date('d/m/Y à H:i') }}
                    </p>
                    {% if event.location %}
                    <p class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">location_on</span>
                        {{ event.location }}
                    </p>
                    {% endif %}
                    {% if event.maxParticipants %}
                    <p class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">group</span>
                        {{ event.maxParticipants }} places
                    </p>
                    {% endif %}
                </div>
                <div class="mt-5 pt-4 border-t border-outline-variant">
                    <a href="{{ path('event_show', {id: event.id}) }}" class="btn-primary w-full justify-center">Voir le détail</a>
                </div>
            </div>
        </div>
    {% endfor %}
    </div>
{% endif %}
{% endblock %}
