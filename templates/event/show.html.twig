{% extends 'base.html.twig' %}
{% block title %}{{ event.title }} - BoisguiBad{% endblock %}

{% block body %}
<a href="{{ path('event_list') }}" class="back-link">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    Retour aux événements
</a>

<div class="max-w-3xl space-y-6">
    <div class="bg-surface-container-lowest rounded-xl shadow-sm p-6">
        <div class="mb-6">
            {% if event.category is defined and event.category %}
                <span class="badge-secondary mb-3 inline-block">{{ event.category.label() }}</span>
            {% endif %}
            <h1 class="text-2xl font-bold text-on-surface">{{ event.title }}</h1>
        </div>

        <div class="dl-grid mb-6">
            <div class="dl-item">
                <dt class="dl-label">Date</dt>
                <dd class="dl-value">{{ event.date|date('d/m/Y à H:i') }}</dd>
            </div>
            {% if event.location %}
            <div class="dl-item">
                <dt class="dl-label">Lieu</dt>
                <dd class="dl-value">{{ event.location }}</dd>
            </div>
            {% endif %}
            {% if event.maxParticipants %}
            <div class="dl-item">
                <dt class="dl-label">Places disponibles</dt>
                <dd class="dl-value">{{ event.availablePlaces }} <span class="text-on-surface-variant font-normal">/ {{ event.maxParticipants }}</span></dd>
            </div>
            {% endif %}
            {% if event.registrationDeadline %}
            <div class="dl-item">
                <dt class="dl-label">Clôture des inscriptions</dt>
                <dd class="dl-value">{{ event.registrationDeadline|date('d/m/Y') }}</dd>
            </div>
            {% endif %}
        </div>

        {% if event.description %}
            <p class="text-on-surface-variant text-sm leading-relaxed mb-6 pb-6 border-b border-outline-variant">{{ event.description }}</p>
        {% endif %}

        {% if registration %}
            <div class="flex flex-wrap items-center gap-3">
                <span class="{% if registration.status.value == 'INSCRIT' %}badge-secondary{% elseif registration.status.value == 'DESISTE' %}badge-error{% else %}badge-amber{% endif %}">
                    {{ registration.status.label() }}
                </span>
                {% if registration.status.value == 'INSCRIT' %}
                    <form method="post" action="{{ path('event_desist', {id: event.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_desist_' ~ event.id) }}">
                        <button class="btn-danger text-xs">Se désister</button>
                    </form>
                    {% if not registration.confirmedAt %}
                    <form method="post" action="{{ path('event_confirm', {id: event.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_confirm_' ~ event.id) }}">
                        <button class="btn-success text-xs">Confirmer ma participation</button>
                    </form>
                    {% else %}
                        <span class="text-sm text-on-surface font-semibold flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">check_circle</span>
                            Participation confirmée
                        </span>
                    {% endif %}
                {% elseif registration.status.value == 'DESISTE' %}
                    <form method="post" action="{{ path('event_register', {id: event.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_register_' ~ event.id) }}">
                        <button class="btn-primary text-xs">Se réinscrire</button>
                    </form>
                {% endif %}
            </div>
        {% else %}
            <form method="post" action="{{ path('event_register', {id: event.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_register_' ~ event.id) }}">
                <button class="btn-primary">S'inscrire à cet événement</button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
