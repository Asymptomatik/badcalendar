<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#1e40af">
    <title>{% block title %}BoisguiBad Club Manager{% endblock %}</title>
    <link rel="manifest" href="/pwa/manifest.json">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@3/base.css">
    <style>
        body { font-family: system-ui, sans-serif; background-color: #f8fafc; }
        .nav-link { @apply text-white hover:bg-blue-700 px-3 py-2 rounded-md text-sm font-medium; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen bg-gray-50">
    <nav class="bg-blue-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center">
                    <a href="{{ path('dashboard_member') }}" class="text-white font-bold text-xl">🏸 BoisguiBad</a>
                    {% if app.user %}
                    <div class="ml-10 flex items-baseline space-x-4">
                        <a href="{{ path('session_list') }}" class="text-blue-200 hover:text-white px-3 py-2 text-sm font-medium">Séances</a>
                        <a href="{{ path('event_list') }}" class="text-blue-200 hover:text-white px-3 py-2 text-sm font-medium">Événements</a>
                        <a href="{{ path('lost_item_list') }}" class="text-blue-200 hover:text-white px-3 py-2 text-sm font-medium">Objets trouvés</a>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}" class="text-yellow-300 hover:text-white px-3 py-2 text-sm font-medium">Admin</a>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
                <div class="flex items-center">
                    {% if app.user %}
                    <span class="text-blue-200 text-sm mr-4">{{ app.user.fullName }}</span>
                    <a href="{{ path('security_logout') }}" class="text-blue-200 hover:text-white text-sm">Déconnexion</a>
                    {% else %}
                    <a href="{{ path('security_login') }}" class="text-blue-200 hover:text-white text-sm mr-4">Connexion</a>
                    <a href="{{ path('security_register') }}" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-500">Inscription</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-4 rounded-md {% if type == 'success' %}bg-green-100 text-green-800{% elseif type == 'error' %}bg-red-100 text-red-800{% else %}bg-blue-100 text-blue-800{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
</body>
</html>
