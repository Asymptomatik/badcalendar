<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#004ac6">
    <title>{% block title %}BoisguiBad{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body class="h-full antialiased font-sans bg-slate-100">

    {# ── Navigation ── #}
    <nav class="sticky top-0 z-50 bg-primary text-on-primary shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">

                <a href="{{ path('dashboard_member') }}" class="flex items-center gap-2 flex-shrink-0">
                    <span class="material-symbols-outlined text-on-primary text-xl">sports_tennis</span>
                    <span class="font-bold text-on-primary text-base hidden sm:block">BoisguiBad</span>
                </a>

                {% if app.user %}
                <div class="hidden md:flex items-center gap-1">
                    <a href="{{ path('session_list') }}" class="btn-ghost">Séances</a>
                    <a href="{{ path('event_list') }}" class="btn-ghost">Événements</a>
                    <a href="{{ path('lost_item_list') }}" class="btn-ghost">Objets trouvés</a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="nav-admin">
                        <span class="material-symbols-outlined text-sm">star</span> Admin
                    </a>
                    {% endif %}
                </div>
                {% endif %}

                <div class="flex items-center gap-3">
                    {% if app.user %}
                    <div class="hidden sm:flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-on-primary/20 flex items-center justify-center flex-shrink-0">
                            <span class="text-on-primary text-xs font-bold">{{ app.user.firstName|slice(0,1)|upper }}{{ app.user.lastName|slice(0,1)|upper }}</span>
                        </div>
                        <span class="text-sm font-medium text-on-primary/90">{{ app.user.firstName }}</span>
                    </div>
                    <a href="{{ path('security_logout') }}" class="text-sm font-medium text-on-primary/70 hover:text-on-primary px-2 py-1.5 rounded transition-colors">
                        Déconnexion
                    </a>
                    {% else %}
                    <a href="{{ path('security_login') }}" class="btn-ghost">Connexion</a>
                    <a href="{{ path('security_register') }}" class="text-sm font-semibold bg-on-primary text-primary px-3 py-1.5 rounded-lg hover:bg-primary-fixed transition-colors">Inscription</a>
                    {% endif %}
                </div>

            </div>
        </div>
    </nav>

    {# ── Contenu ── #}
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="{% if type == 'success' %}alert-success{% elseif type == 'error' %}alert-error{% elseif type == 'warning' %}alert-warning{% else %}alert-info{% endif %}">
                <span class="material-symbols-outlined text-base flex-shrink-0">
                    {% if type == 'success' %}check_circle{% elseif type == 'error' %}error{% elseif type == 'warning' %}warning{% else %}info{% endif %}
                </span>
                {{ message }}
            </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</body>
</html>
